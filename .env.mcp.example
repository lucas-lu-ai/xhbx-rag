# 复制为 .env.mcp 并填入真实凭证。
# docker-compose.mcp.yml 会在 mcp 容器内把 MILVUS_URI 覆盖为 http://standalone:19530；
# 因此这里保留 localhost，方便宿主机直接运行 uv 命令调试 Docker Milvus。

API_KEY=
BASE_URL=
MODEL_NAME=
VISION_MODEL_NAME=

EMBEDDING_BASE_URL=https://api.siliconflow.com/v1
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-8B
EMBEDDING_API_KEY=

RERANK_BASE_URL=https://api.siliconflow.com/v1
RERANK_MODEL_NAME=Qwen/Qwen3-Reranker-8B
RERANK_API_KEY=

MILVUS_MODE=docker
MILVUS_LITE_PATH=.local/milvus/xhbx_rag.db
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=xhbx_knowledge_chunks
MILVUS_COURSE_COLLECTION=xhbx_course_chunks
MILVUS_VECTOR_DIM=

# MCP 服务端口。
# 默认只绑定宿主机 127.0.0.1；如需可信内网直连，可改为 0.0.0.0。
MCP_BIND=127.0.0.1
MCP_PORT=9331

# MCP tool 暴露模式：
# kb     = 默认，只暴露 kb_list_knowledge_bases / kb_search_knowledge
# legacy = 只暴露旧 search_knowledge / retrieval_status / list_filter_options
# both   = 新旧 tool 都暴露，适合灰度切换
MCP_TOOL_PROFILE=kb

# 离线部署目标服务器平台。普通 x86_64 服务器使用 linux/amd64。
# 如果目标服务器是 ARM64，再改为 linux/arm64。
DOCKER_PLATFORM=linux/amd64

# 宿主机调试端口，默认只绑定 127.0.0.1。
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091

# 批量入库脚本 scripts/index_parsed.sh 可选参数。
# 默认先规范化 parsed 全部 chunk，再原子重建统一 collection。
# PARSED_DIR=parsed
# NORMALIZED_DIR=parsed_normalized
# COLLECTION_NAME=xhbx_knowledge_chunks
# BATCH_SIZE=64
