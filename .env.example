# 第三方 OpenAI 兼容平台凭证（复制为 .env 并填入真实值）
API_KEY=
BASE_URL=
MODEL_NAME=

# 向量化模型
EMBEDDING_BASE_URL=
EMBEDDING_MODEL_NAME=
EMBEDDING_API_KEY=

# rerank模型
RERANK_BASE_URL=
RERANK_MODEL_NAME=
RERANK_API_KEY=

# milvus向量库配置
MILVUS_MODE=docker
MILVUS_LITE_PATH=.local/milvus/xhbx_rag.db
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=xhbx_sales_chunks
MILVUS_COURSE_COLLECTION=xhbx_course_chunks
MILVUS_VECTOR_DIM=

# Web 端 AgentScope Studio 观测
WEB_STUDIO_TRACE=false
WEB_STUDIO_ENDPOINT=localhost:4317

# Web 批量执行并发数（1-10，仅 MILVUS_MODE=docker 时生效；lite 模式强制串行）
WEB_BATCH_CONCURRENCY=3

# Web 单次问答与批量执行共用的检索数量
WEB_RETRIEVAL_TOP_N=20
WEB_RETRIEVAL_TOP_K=5

# Web 文档入库上传与 ZIP 安全限制（大小单位为字节，压缩比无单位）
WEB_INGEST_MAX_UPLOAD_BYTES=536870912
WEB_INGEST_MAX_ZIP_ENTRIES=2000
WEB_INGEST_MAX_EXTRACTED_BYTES=2147483648
WEB_INGEST_MAX_ENTRY_BYTES=536870912
WEB_INGEST_MAX_COMPRESSION_RATIO=100
