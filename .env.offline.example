# 复制为 .env，并替换成私有环境内的真实模型配置。
# 当前程序要求三个 API_KEY 字段非空；内网模型不鉴权时可填写 not-required。

# Chat 模型：BASE_URL 应为能拼接 /chat/completions 的 OpenAI 兼容根地址。
API_KEY=
BASE_URL=
MODEL_NAME=
VISION_MODEL_NAME=

# Embedding 模型：BASE_URL 应为能拼接 /embeddings 的 OpenAI 兼容根地址。
EMBEDDING_BASE_URL=
EMBEDDING_MODEL_NAME=
EMBEDDING_API_KEY=

# Rerank 模型：BASE_URL 应为能拼接 /rerank 的服务根地址。
RERANK_BASE_URL=
RERANK_MODEL_NAME=
RERANK_API_KEY=

# Compose 会在 api/cli 容器内把 MILVUS_URI 覆盖为 standalone 服务地址。
MILVUS_MODE=docker
MILVUS_LITE_PATH=.local/milvus/xhbx_rag.db
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=xhbx_sales_chunks
MILVUS_COURSE_COLLECTION=xhbx_course_chunks
MILVUS_VECTOR_DIM=

WEB_STUDIO_TRACE=false
WEB_STUDIO_ENDPOINT=localhost:4317
WEB_BATCH_CONCURRENCY=3
WEB_RETRIEVAL_TOP_N=20
WEB_RETRIEVAL_TOP_K=5

WEB_INGEST_MAX_UPLOAD_BYTES=536870912
WEB_INGEST_MAX_ZIP_ENTRIES=2000
WEB_INGEST_MAX_EXTRACTED_BYTES=2147483648
WEB_INGEST_MAX_ENTRY_BYTES=536870912
WEB_INGEST_MAX_COMPRESSION_RATIO=100

# 宿主机端口。只有 Web 默认对内网开放，其余调试端口绑定 127.0.0.1。
WEB_PORT=18088
API_PORT=8000
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
