# 复制为 .env 并填入真实凭证。
# compose 会在 api/cli 容器内把 MILVUS_URI 覆盖为 http://standalone:19530；
# 因此这里保留 localhost，方便宿主机直接运行 uv 命令调试 Docker Milvus。

API_KEY=
BASE_URL=
MODEL_NAME=
VISION_MODEL_NAME=

EMBEDDING_BASE_URL=https://api.siliconflow.com/v1
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-8B
EMBEDDING_API_KEY=

RERANK_BASE_URL=https://api.siliconflow.com/v1
RERANK_MODEL_NAME=Qwen/Qwen3-Reranker-8B
RERANK_API_KEY=

MILVUS_MODE=docker
MILVUS_LITE_PATH=.local/milvus/xhbx_rag.db
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=xhbx_sales_chunks
MILVUS_VECTOR_DIM=

WEB_STUDIO_TRACE=false
WEB_STUDIO_ENDPOINT=localhost:4317
WEB_BATCH_CONCURRENCY=3
WEB_RETRIEVAL_TOP_N=20
WEB_RETRIEVAL_TOP_K=5

# 宿主机端口。API/Milvus/MinIO 调试端口默认只绑定 127.0.0.1。
WEB_PORT=8080
API_PORT=8000
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
